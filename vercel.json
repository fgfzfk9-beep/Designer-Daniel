{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/style.css", "use": "@vercel/static" },
    { "src": "public/script.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "source": "/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "source": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
